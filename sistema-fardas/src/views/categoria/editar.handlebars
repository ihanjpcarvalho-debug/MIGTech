<h2>Editar Categoria</h2>

<form action="/categorias/{{categoria.id}}" method="POST">

  <label>

    Nome

  </label>

  <br />

  <input type="text" name="nome" value="{{categoria.nome}}" required />

  <br /><br />

  <label>

    Descrição

  </label>

  <br />

  <input type="text" name="descricao" value="{{categoria.descricao}}" />

  <br /><br />

  <label>

    Ativa

  </label>

  <br />

  <select name="ativa">

    <option value="true">

      Sim

    </option>

    <option value="false">

      Não

    </option>

  </select>

  <br /><br />

  <button>

    Salvar

  </button>

</form>

<br />

<a href="/categorias">

  Voltar

</a>