<h1>Categorias</h1>

<a href="/categorias/nova">
  Nova Categoria
</a>

<br /><br />

<table border="1" cellpadding="8">

  <tr>

    <th>ID</th>
    <th>Nome</th>
    <th>Situação</th>
    <th>Ações</th>

  </tr>

  {{#each categorias}}

    <tr>

      <td>{{id}}</td>

      <td>{{nome}}</td>

      <td>{{situacao}}</td>

      <td>

        <a href="/categorias/{{id}}/editar">
          Editar
        </a>

        |

        <form
          action="/categorias/{{id}}/excluir"
          method="POST"
          style="display:inline;"
        >

          <button type="submit">
            Excluir
          </button>

        </form>

      </td>

    </tr>

  {{/each}}

</table>