<h2>Categorias</h2>

<a href="/categorias/nova">

  Cadastrar nova categoria

</a>

<br /><br />

<table border="1">

  <tr>

    <th>ID</th>

    <th>Nome</th>

    <th>Descrição</th>

    <th>Ativa</th>

    <th>Ações</th>

  </tr>

  {{#each categorias}}

    <tr>

      <td>{{id}}</td>

      <td>{{nome}}</td>

      <td>{{descricao}}</td>

      <td>

        {{#if ativa}}

          Sim

        {{else}}

          Não

        {{/if}}

      </td>

      <td>

        <a href="/categorias/{{id}}/editar">

          Editar

        </a>

        <form action="/categorias/{{id}}/excluir" method="POST">

          <button>

            Excluir

          </button>

        </form>

      </td>

    </tr>

  {{/each}}

</table>