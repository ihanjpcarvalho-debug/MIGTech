<h2>Editar Fardamento</h2>
<form action="/fardamentos/{{fardamento.id}}" method="POST">
  <label>Camisa</label><br />
  <input type="text" name="camisa" value="{{fardamento.camisa}}" required /><br /><br />

  <label>Short</label><br />
  <input type="text" name="short" value="{{fardamento.short}}" required /><br /><br />

  <label>Tamanho</label><br />
  <select name="tamanho">
    <option value="P" {{#if (eq fardamento.tamanho "P")}}selected{{/if}}>P</option>
    <option value="M" {{#if (eq fardamento.tamanho "M")}}selected{{/if}}>M</option>
    <option value="G" {{#if (eq fardamento.tamanho "G")}}selected{{/if}}>G</option>
    <option value="GG" {{#if (eq fardamento.tamanho "GG")}}selected{{/if}}>GG</option>
  </select><br /><br />

  <label>Quantidade</label><br />
  <input type="number" name="quantidade" min="1" value="{{fardamento.quantidade}}" required /><br /><br />

  <label>Categoria</label><br />
  <select name="categoriaId">
    <option value="">Sem categoria</option>
    {{#each categorias}}
      <option value="{{this.id}}" {{#if (eq ../fardamento.categoriaId this.id)}}selected{{/if}}>{{this.nome}}</option>
    {{/each}}
  </select><br /><br />

  <label>Registro de Entrega</label><br />
  <input type="date" name="entrega" value="{{fardamento.entrega}}" required /><br /><br />

  <button type="submit">Salvar</button>
</form>

<a href="/fardamentos">Voltar</a>
