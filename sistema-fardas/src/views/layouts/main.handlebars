<html lang="pt-br">

  <head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistema de Fardamentos</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        background: #f7f9fc;
        color: #222;
      }
      header {
        background: #2f4f4f;
        color: white;
        padding: 16px 20px;
      }
      nav {
        margin-top: 8px;
      }
      nav a {
        color: white;
        text-decoration: none;
        margin-right: 10px;
        font-size: 14px;
      }
      .card {
        max-width: 760px;
        margin: 20px auto;
        padding: 20px;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
      }
      h2 {
        color: #2f4f4f;
        margin-top: 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
      }
      th,
      td {
        padding: 8px;
        border-bottom: 1px solid #eee;
        text-align: left;
      }
      th {
        background: #f2f5f8;
      }
      .formulario-fardamento {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      input,
      select,
      button {
        padding: 8px;
        border-radius: 6px;
        border: 1px solid #ccc;
      }
      button {
        background: #2f4f4f;
        color: white;
        cursor: pointer;
        border: none;
      }
      a {
        color: #2f4f4f;
      }
    </style>

  </head>

  <body>

    <header>

      <h1>Sistema de Controle de Fardamentos</h1>

      <hr />

      <nav>

        <a href="/">Início</a>
        |

        <a href="/categorias">Categorias</a>
        |

        <a href="/fardamentos">Fardamentos</a>
        |

        <a href="/movimentacoes">Movimentações</a>

      </nav>

      <hr />

    </header>

    {{{body}}}

  </body>

</html>